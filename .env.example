DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# Optional: set SKIP_DOTENV=True in production if your host injects env vars.
SKIP_DOTENV=False

DB_NAME=rentfair
DB_USER=rentfair_user
DB_PASSWORD=replace-with-production-db-password
DB_HOST=replace-with-production-db-host
DB_PORT=3306
# Render/PostgreSQL style. If set, this overrides the DB_* values above.
# Example: postgres://user:password@host:5432/database
DATABASE_URL=
# Optional for external PostgreSQL connections that require SSL.
DB_SSLMODE=require
DB_CONN_MAX_AGE=600

# Uploaded property photos/documents.
# Paste your Cloudinary URL to store uploaded media safely.
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
